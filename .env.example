# MonsterBorg Blockly Environment Variables
# Copy this file to .env and update with your settings

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# Robot Configuration
ROBOT_ENABLED=True
MOCK_ROBOT=False  # Set to True for testing without hardware

# Camera Configuration
CAMERA_ENABLED=True
MOCK_CAMERA=False  # Set to True for testing without camera

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/monsterborg.log